# Environment Configuration
# Web URLs for different environments
#
# Active mode: which API_* / SURVEY_FRONTEND_* keys are used (dev | staging | prod).
APP_ENV=dev

# API Base URLs
API_BASE_URL_PROD=https://survey-api.system2030.com
API_BASE_URL_DEV=https://survey-api.system2030.com
API_BASE_URL_STAGING=https://survey-api.system2030.com

# Frontend Base URLs
SURVEY_FRONTEND_BASE_URL_PROD=https://survey-frontend.system2030.com
SURVEY_FRONTEND_BASE_URL_DEV=https://survey-frontend.system2030.com
SURVEY_FRONTEND_BASE_URL_STAGING=https://survey-frontend.system2030.com

# Default locale for survey links
SURVEY_DEFAULT_LOCALE=ar
