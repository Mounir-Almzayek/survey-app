# Environment Configuration
#
# The active env (dev | staging | prod) is driven by the Flutter flavor passed
# to `flutter run --flavor <name>` (propagated as FLUTTER_APP_FLAVOR at build
# time). See lib/core/config/app_environment.dart.

# API Base URLs
API_BASE_URL_PROD=https://survey-api.system2030.com
API_BASE_URL_DEV=https://survey-api-test.system2030.com
API_BASE_URL_STAGING=https://survey-api-test.system2030.com

# Frontend Base URLs
SURVEY_FRONTEND_BASE_URL_PROD=https://survey-frontend.system2030.com
SURVEY_FRONTEND_BASE_URL_DEV=https://survey-front-internal.system2030.com
SURVEY_FRONTEND_BASE_URL_STAGING=https://survey-front-internal.system2030.com

# Default locale for survey links
SURVEY_DEFAULT_LOCALE=ar
